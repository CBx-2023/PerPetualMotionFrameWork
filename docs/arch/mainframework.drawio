    <mxCell id="right_label" value="为什么能“永动”：三个自补给回路" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#243447;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
      <mxGeometry x="1275" y="170" width="430" height="34" as="geometry"/>
    </mxCell>
    <mxCell id="loop_context" value="① 上下文飞轮：Graphify&lt;br&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;每次大改后更新知识图谱；下一轮先查图再行动。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Contextₜ₊₁ = Contextₜ + GraphDelta + Evidence&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#edf7ef;strokeColor=#3b7451;strokeWidth=1.4;fontSize=17;fontStyle=1;fontColor=#214a32;fontFamily=Microsoft YaHei;align=left;spacing=12;" vertex="1" parent="1">
      <mxGeometry x="1280" y="230" width="430" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="loop_method" value="② 方法飞轮：Agent Skills / Superpowers&lt;br&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;任务类型触发对应工程流程，避免每轮重新发明做法。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Actionₜ = policy(task_type, risk, evidence_gap)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f4eff9;strokeColor=#73568b;strokeWidth=1.4;fontSize=17;fontStyle=1;fontColor=#4d3562;fontFamily=Microsoft YaHei;align=left;spacing=12;" vertex="1" parent="1">
      <mxGeometry x="1280" y="380" width="430" height="124" as="geometry"/>
    </mxCell>
    <mxCell id="loop_execution" value="③ 执行飞轮：Missions + /goal&lt;br&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;CSV 记录任务、状态、验证策略和缺口；中断后继续同一状态机。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Queueₜ₊₁ = unfinished(Qₜ) + follow_up(gaps)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2df;strokeColor=#916234;strokeWidth=1.4;fontSize=17;fontStyle=1;fontColor=#603b17;fontFamily=Microsoft YaHei;align=left;spacing=12;" vertex="1" parent="1">
      <mxGeometry x="1280" y="535" width="430" height="132" as="geometry"/>
    </mxCell>
    <mxCell id="stop_rule" value="终止条件&lt;br&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;不是“跑完若干步骤”，而是 REVIEW 行证明原始目标已满足；否则缺口继续进入 follow-up issue。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fbecec;strokeColor=#8b3d3d;strokeWidth=1.4;fontSize=17;fontStyle=1;fontColor=#633030;fontFamily=Microsoft YaHei;align=left;spacing=12;" vertex="1" parent="1">
      <mxGeometry x="1280" y="700" width="430" height="112" as="geometry"/>
    </mxCell>
    <mxCell id="not_perpetual" value="“永动”的真实含义：系统不会凭空产出能量；新能量来自用户目标、工具验证、代码 diff、审查结论和风险缺口。框架做的是把这些输入持续转化为下一轮可执行状态。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#17202a;strokeColor=#17202a;strokeWidth=1;fontSize=13;fontColor=#ffffff;fontFamily=Microsoft YaHei;align=left;spacing=12;" vertex="1" parent="1">
      <mxGeometry x="1280" y="842" width="430" height="72" as="geometry"/>
    </mxCell>
